# ============================================================
#  Inventory Management System — .gitignore
#  KEEP THIS FILE.  Everything below is intentionally ignored.
# ============================================================

# ── Secrets & Environment ────────────────────────────────────
# NEVER commit real credentials. Use .env.example for templates.
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
*.pem
*.key
*.cert
*.p12
*.pfx
secrets.json
secrets.yaml
secrets.yml

# ── Node / Frontend ────────────────────────────────────────
node_modules/
dist/
dist-ssr/
build/
.vite/
*.local

# TypeScript build info (auto-generated, not needed in repo)
*.tsbuildinfo
tsconfig.app.tsbuildinfo
tsconfig.node.tsbuildinfo

# Vite generated files
vite.config.d.ts
vite.config.js

# ── Python / FastAPI backend ─────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
*.so

# Virtual environments
.venv/
venv/
env/
ENV/
.env/
venv.bak/

# Python packaging / distribution
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
*.whl

# Pytest / test cache
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# mypy / pyright type caching
.mypy_cache/
.pytype/
.pyre/
pyrightconfig.json

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS-generated files ────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editors & IDEs ───────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Miscellaneous ─────────────────────────────────────────────
*.zip
*.tar.gz
*.rar
.cache/
.temp/
.tmp/
tmp/
